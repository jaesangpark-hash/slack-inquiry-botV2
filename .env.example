# ============================================================
# slack-inquiry-bot .env.example
# 사용법: 이 파일을 .env로 복사 후 아래 23종 환경변수를 채우면 npm start 즉시 구동
# cp .env.example .env
# ============================================================
# ⚠️ 보안 주의: .env 파일에 실제 토큰·시트 ID를 채운 뒤 git에 커밋하지 마세요.
#              .gitignore에 .env가 이미 포함되어 있습니다.
# ============================================================

# ------------------------------------------------------------
# [1] assertSecretsBase — Slack + AI + Totus 게이트웨이 + Google (7종)
# ------------------------------------------------------------

# Slack Bot Token — Slack App 관리 페이지 > OAuth & Permissions > Bot User OAuth Token (xoxb-...)
# 기존 봇의 Token을 그대로 재사용 가능
SLACK_BOT_TOKEN=

# Slack App-Level Token — Slack App 관리 페이지 > Basic Information > App-Level Tokens (xapp-...)
# Socket Mode 연결에 필요. 기존 토큰 재사용 가능
SLACK_APP_TOKEN=

# Gemini API Key — Google AI Studio (aistudio.google.com) 에서 발급
# 기존 키 재사용 가능
GEMINI_API_KEY=

# Gemini 모델명 — 사용할 Gemini 모델 ID (예: gemini-2.5-flash)
# 기존 설정값 재사용 가능
GEMINI_MODEL=

# PLATFORM API URL — Totus write 게이트웨이 (REST 엔드포인트)
# 봇의 파일 발주 등 write 요청 전용 게이트웨이
# 기존 PLATFORM_API_URL 값 재사용 가능
PLATFORM_API_URL=

# PLATFORM API Token — Totus write 게이트웨이 인증 토큰
# 기존 PLATFORM_API_TOKEN 값 재사용 가능
PLATFORM_API_TOKEN=

# Google Credentials — Google service account JSON 전체를 한 줄 문자열로 인코딩한 값
# Sheets/Drive API 접근용. base64 인코딩 또는 JSON 문자열 직접 입력(설정 방식은 기존 운영 방식 참고)
# 기존 service account 재사용 가능
GOOGLE_CREDENTIALS=

# ------------------------------------------------------------
# [2] assertGoogleSheets — Google Sheets ID 및 범위 (9종)
# ------------------------------------------------------------

# 마스터 시트 ID — 작품명 매칭 기준 시트 (title-matcher 사용)
# 기존 MASTER_SHEET_ID 재사용 가능
MASTER_SHEET_ID=

# 납품 시트 ID — 납품 일정 조회 기준 시트 (delivery-date 사용)
# 기존 DELIVERY_SHEET_ID 재사용 가능
DELIVERY_SHEET_ID=

# 납품 시트 한일 범위 — 납품 시트 내 한일(KO→JA) 탭 범위 (예: 한일!A:Z)
# 기존 DELIVERY_SHEET_KO_JA 재사용 가능
DELIVERY_SHEET_KO_JA=

# 납품 시트 중일 범위 — 납품 시트 내 중일(ZH→JA) 탭 범위 (예: 중일_master!A:Z)
# 기존 DELIVERY_SHEET_ZH_JA 재사용 가능
DELIVERY_SHEET_ZH_JA=

# 수급 시트 ID — 재수급 요청 대상 시트 (resupply-record 사용)
# 기존 RESUPPLY_SHEET_ID 재사용 가능
RESUPPLY_SHEET_ID=

# 수급 시트 범위 — 수급 시트 내 읽기/쓰기 범위 (예: Sheet1!A:G)
# 기존 RESUPPLY_SHEET_RANGE 재사용 가능
RESUPPLY_SHEET_RANGE=

# 작업자 시트 ID — 작업자 목록 시트 (collectWorkers 스크립트 + title-matcher 사용)
# 기존 WORKER_SHEET_ID 재사용 가능
WORKER_SHEET_ID=

# 작업자 시트 범위 — 작업자 시트 내 읽기 범위 (예: Sheet1!A:F)
# 기존 WORKER_SHEET_RANGE 재사용 가능
WORKER_SHEET_RANGE=

# Google Sheets 기본 범위 — 마스터 시트 등 기본 read 범위
# 기존 GOOGLE_SHEET_RANGE 재사용 가능
GOOGLE_SHEET_RANGE=

# ------------------------------------------------------------
# [3] assertChannels — Slack 채널/유저 ID (6종)
# ------------------------------------------------------------

# PM Slack User ID — PM에게 DM 발송 시 사용하는 Slack User ID (UXXXXXXXXX 형식)
# Slack 프로필 URL 또는 /slack users.list API로 확인
PM_SLACK_ID=

# 메인 문의 채널 ID — 봇이 문의를 수신하는 주 채널 ID (CXXXXXXXXX 형식)
# 기존 TARGET_CHANNEL_ID 재사용 가능
TARGET_CHANNEL_ID=

# PM 요청 채널 ID — PM 요청 전달용 채널 ID
# 기존 PM_REQUEST_CHANNEL_ID 재사용 가능
PM_REQUEST_CHANNEL_ID=

# 스케줄 채널 ID — 일정 관련 알림 채널 ID
# 기존 SCHEDULE_CHANNEL_ID 재사용 가능
SCHEDULE_CHANNEL_ID=

# 포워드 멘션 유저 ID — 문의 포워딩 시 멘션할 유저 ID (UXXXXXXXXX)
# 기존 FORWARD_MENTION_USER_ID 재사용 가능
FORWARD_MENTION_USER_ID=

# 리테이크 채널 ID 목록 — 리테이크 알림을 전달할 채널 ID (쉼표 구분, 예: C111,C222)
# 기존 RETAKE_CHANNELS 재사용 가능
RETAKE_CHANNELS=

# ------------------------------------------------------------
# [4] assertTriggerEmoji — 트리거 이모지 (1종)
# ------------------------------------------------------------

# 트리거 이모지 — reaction_added 핸들러 활성 조건 커스텀 이모지명 (콜론 제외, 예: 문의봇소환)
# Slack workspace에 커스텀 이모지를 먼저 등록해야 합니다.
# 봇 Slack App에 reactions:read 및 reactions:write scope 필요 (대응완료 마킹에 사용)
# 기존 트리거 이모지명 재사용 가능
TRIGGER_EMOJI=

# ------------------------------------------------------------
# [KPI 활성 시만] assertKpiSheets — KPI 분석 시트 (현재 미사용)
# 향후 KPI 기능 활성화 시 주석 해제 후 값 입력
# ------------------------------------------------------------

# KPI 문의 이력 시트 ID
#INQUIRY_HISTORY_SHEET_ID=

# KPI 문의 이력 시트 범위
#INQUIRY_HISTORY_SHEET_RANGE=
